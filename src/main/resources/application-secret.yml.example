# Supabase 연결 설정 예시
# 이 파일을 복사해서 application-secret.yml 로 만들고 실제 값을 채워주세요.
# application-secret.yml 은 절대 커밋하지 마세요!
#
# Supabase 프로젝트 설정 위치:
#   Project Settings > Database > Connection string > URI (JDBC 형식)
#   Project Settings > Database > Database password

spring:
  datasource:
    url: jdbc:postgresql://db.YOUR_PROJECT_REF.supabase.co:5432/postgres
    username: postgres
    password: YOUR_DATABASE_PASSWORD
